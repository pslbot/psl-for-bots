{
  "name": "@psl/cli",
  "version": "1.0.0",
  "description": "Command-line interface for PSL Bot",
  "bin": {
    "psl": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/cli.ts src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "keywords": ["psl", "cli", "command-line"],
  "license": "MIT",
  "dependencies": {
    "@psl/core": "workspace:*",
    "@psl/types": "workspace:*",
    "@psl/logger": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
